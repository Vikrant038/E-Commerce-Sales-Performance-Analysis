# Copy this file to `.streamlit/secrets.toml` (gitignored) to enable the
# AI "Ask the data" feature locally. On Streamlit Community Cloud, paste the
# same keys under App → Settings → Secrets instead.
#
# The dashboard works fully WITHOUT any of these — the AI tab just shows a notice.
#
# Add ANY ONE provider key and it is used automatically. If several are present,
# the order of preference is: Anthropic → OpenAI → Gemini (override with LLM_PROVIDER).

# --- Pick one (or more) ---
ANTHROPIC_API_KEY = "sk-ant-..."
# OPENAI_API_KEY  = "sk-..."
# GEMINI_API_KEY  = "AIza..."

# --- Optional overrides ---
# LLM_PROVIDER = "anthropic"          # force a provider: anthropic | openai | gemini
# LLM_MODEL    = "claude-haiku-4-5"   # cheaper/faster model for a public demo
#   anthropic default: claude-opus-4-8   (cheap: claude-haiku-4-5)
#   openai    default: gpt-4o-mini
#   gemini    default: gemini-2.0-flash
