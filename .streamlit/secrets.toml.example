# Copy this file to `.streamlit/secrets.toml` (gitignored) to enable the
# AI "Ask the data" feature locally. On Streamlit Community Cloud, paste the
# same keys under App → Settings → Secrets instead.
#
# The dashboard works fully WITHOUT any of these — the AI tab just shows a notice.

ANTHROPIC_API_KEY = "sk-ant-..."

# Optional overrides:
# LLM_PROVIDER = "anthropic"          # only "anthropic" is implemented today
# LLM_MODEL    = "claude-haiku-4-5"   # cheaper/faster model for a public demo
