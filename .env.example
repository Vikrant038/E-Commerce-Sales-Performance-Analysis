# Documents the environment variables the app reads (GUARDRAILS 1.4).
# Copy to `.env` (gitignored) for local use, or set these in your shell /
# Streamlit Cloud secrets. The app reads st.secrets first, then the environment.
# Every variable is OPTIONAL — without a key, the AI tab is simply disabled.

# Add any ONE provider key (preference order: anthropic > openai > gemini):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional overrides:
LLM_PROVIDER=
LLM_MODEL=
